profiles {
    debug{
        cleanup = false
    }
    Hominidae {
        params.database  = "${projectDir}/assets/Hominidae/Hominidae_k21.idx"  // a folder with the Kallisto database, Zavala2021-version provided in assets
        params.labels    = "${projectDir}/assets/Hominidae/labels.tsv"
        params.outdir    = "kallisto_hominidae"
    }
    Hyaenidae {
        params.database  = "${projectDir}/assets/Hyaenidae/Hyaenidae_k21.idx"
